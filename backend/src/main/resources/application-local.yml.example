# =============================================
# 本地开发环境配置
# 使用方式：
#   1. 复制此文件为 application-local.yml
#   2. 修改数据库密码和 JWT Secret
#   3. 首次启动前，先运行 scripts/init-database.sql 初始化基础数据：
#      docker exec -i supplypro-mysql mysql -u root -ppassword supplypro < scripts/init-database.sql
#   4. 启动：./mvnw spring-boot:run -Dspring-boot.run.profiles=local
#
# 注意：Flyway baseline-version 设为 5.100，意味着 V1.0~V5.x 的迁移脚本
# 不会在新数据库上执行。因此 ddl-auto 必须设为 update 以自动创建表结构，
# 同时必须手动执行 init-database.sql 导入种子数据。
# =============================================

spring:
  datasource:
    url: jdbc:mysql://127.0.0.1:3307/supplypro?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useUnicode=true&characterEncoding=utf-8
    driver-class-name: com.mysql.cj.jdbc.Driver
    username: root
    password: YOUR_DB_PASSWORD
  jpa:
    database-platform: org.hibernate.dialect.MySQL8Dialect
    hibernate:
      # 本地开发：update 自动建表（因为 Flyway baseline 跳过了 V1-V5 迁移）
      ddl-auto: update
    show-sql: true
  flyway:
    # 启用 Flyway 以创建 flyway_schema_history 表并记录基线
    enabled: true
    baseline-on-migrate: true
    baseline-version: "5.100"
  mvc:
    pathmatch:
      matching-strategy: ant_path_matcher

supplypro:
  app:
    jwtSecret: YOUR_JWT_SECRET_KEY_AT_LEAST_64_CHARACTERS_LONG_FOR_HS256_ALGORITHM
    jwtExpirationMs: 86400000

file:
  upload-dir: uploads
  allowed-types: jpg,jpeg,png,pdf,doc,docx,xls,xlsx
